generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- ENUMS ----------------

enum ZodiacSign {
  aries
  taurus
  gemini
  cancer
  leo
  virgo
  libra
  scorpio
  sagittarius
  capricorn
  aquarius
  pisces
}

enum SubscriptionStatus {
  trial
  active
  canceled
  expired
  grace
  paused // Добавил статус для явной паузы подписки
  pending
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  canceled // Добавил, если пользователь отменил на форме оплаты
}

enum PlanName {
  basic
  plus
  premium
}

// Добавил Enum для валют, чтобы не хранить произвольные строки
enum Currency {
  BYN
  RUB
  USD
  CNY
  KZT
}

// ---------------- MODELS ----------------

model User {
  id           String      @id @default(uuid())
  telegramId   BigInt?     @unique @map("telegram_id")
  email        String?     @unique
  zodiacSign   ZodiacSign? @map("zodiac_sign")
  birthDate    DateTime?   @map("birth_date") @db.Date
  
  timezone     String      @default("Europe/Minsk")
  
  // Локаль: 'ru', 'en', 'es', 'zh'
  locale       String      @default("ru") 
  
  // Страна (ISO 3166-1 alpha-2): 'BY', 'RU', 'US', 'CN'. 
  // Важно для выбора платежного шлюза.
  countryCode  String?     @map("country_code") @db.Char(2)

  deliveryTime String      @default("07:00:00") @map("delivery_time")
  isPaused     Boolean     @default(false) @map("is_paused")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  subscriptions    Subscription[]
  payments         Payment[]
  deliveries       Delivery[]
  partners         UserPartner[]
  giftsSent        GiftSubscription[] @relation("GiftSender")

  @@index([zodiacSign])
  @@map("users")
}

model Plan {
  id            String   @id @default(uuid())
  name          PlanName @unique
  
  createdAt     DateTime @default(now()) @map("created_at")

  prices           PlanPrice[] // Связь с ценами
  subscriptions    Subscription[]
  giftSubscriptions GiftSubscription[]

  @@map("plans")
}

// НОВАЯ МОДЕЛЬ: Цены для разных регионов/валют
model PlanPrice {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  currency  Currency // USD, EUR, RUB, etc.
  
  // Сумма в МИНИМАЛЬНЫХ единицах валюты (центы, копейки).
  // Например, $10.00 храним как 1000.
  amount    Int      
  locale      String   @default("ru") 
  
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, currency]) // У плана может быть только одна цена в конкретной валюте
  @@map("plan_prices")
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  planId          String             @map("plan_id")
  
  status          SubscriptionStatus @default(trial)
  
  // Важно: какую валюту/цену зафиксировали при подписке
  currency        Currency           @default(BYN) 
  priceAmount     Int                @map("price_amount") // Цена продления (в копейках/центах)

  trialEndsAt     DateTime?          @map("trial_ends_at")
  startAt         DateTime           @default(now()) @map("start_at")
  renewAt         DateTime?          @map("renew_at")
  canceledAt      DateTime?          @map("canceled_at")
  
  // Провайдеры теперь будут разные: 'yookassa', 'stripe', 'alipay', 'bepaid'
  paymentProvider String             @default("bepaid") @map("payment_provider")
  
  // Token рекуррентного платежа (payment_method_id в Stripe, saved_card_id в Yookassa)
  paymentToken    String?            @map("payment_token") 
  
  // ID подписки на стороне шлюза (актуально для Stripe Subscriptions)
  externalSubId   String?            @map("external_sub_id")

  lastPaymentId   String?            @map("last_payment_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([renewAt])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  subscriptionId    String?       @map("subscription_id")
  
  // ID транзакции на стороне платежной системы
  providerPaymentId String?       @map("provider_payment_id") 
  
  // Уникальный ID заказа в нашей системе
  orderId           String        @unique @map("order_id")
  
  // Деньги: отвязываем от BYN
  amount            Int           // В копейках/центах
  currency          Currency      @default(BYN)
  
  status            PaymentStatus @default(pending)
  isRecurring       Boolean       @default(false) @map("is_recurring")
  
  // Метаданные (IP пользователя, UserAgent, ошибки от шлюза)
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  giftSubscription GiftSubscription?

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("payments")
}

model AstroEvent {
  id          String     @id @default(uuid())
  eventDate   DateTime   @map("event_date") @db.Date
  planet      String
  sign        ZodiacSign?
  aspect      String?
  magnitude   Float?
  source      String?    // Техническое поле источника данных
  
  // Описание может быть на разных языках, поэтому лучше JSONB 
  // или отдельная таблица. Для событий часто хватает JSONB: {"ru": "...", "en": "..."}
  description Json?      
  
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([eventDate])
  @@map("astro_events")
}

// ИЗМЕНЕНО: Forecast теперь содержит только "скелет" данных. Тексты вынесены.
model Forecast {
  id           String     @id @default(uuid())
  forecastDate DateTime   @map("forecast_date") @db.Date
  zodiacSign   ZodiacSign @map("zodiac_sign")

  // Технические метрики (языконезависимые) могут остаться здесь
  luckyMetrics Json       @default("{}") @map("lucky_metrics")
  
  // Источник генерации
  source       Json       @default("{}")
  generatedAt  DateTime   @default(now()) @map("generated_at")

  translations ForecastTranslation[] // Связь с текстами на разных языках
  deliveries   Delivery[]

  @@unique([forecastDate, zodiacSign])
  @@index([forecastDate, zodiacSign])
  @@map("forecasts")
}

// НОВАЯ МОДЕЛЬ: Локализованные тексты прогнозов
model ForecastTranslation {
  id          String   @id @default(uuid())
  forecastId  String   @map("forecast_id")
  locale      String   @default("ru") // "ru", "en", "de"

  // --- BASIC PLAN TEXTS ---
  love        String   @db.Text
  money       String   @db.Text
  mood        String   @db.Text
  advice      String   @db.Text

  // --- PLUS PLAN TEXTS ---
  affirmation String   @default("") @db.Text
  compatibility Json   @default("{}") // Текст внутри JSON тоже должен быть локализован

  // --- PREMIUM PLAN TEXTS ---
  tomorrowInsight String @default("") @map("tomorrow_insight") @db.Text

  forecast    Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, locale]) // Один язык на один прогноз
  @@map("forecast_translations")
}

// ИЗМЕНЕНО: Шаблоны уведомлений теперь мультиязычные
model ContentTemplate {
  id           String     @id @default(uuid())
  zodiacSign   ZodiacSign? @map("zodiac_sign")
  triggerType  String     @map("trigger_type") // e.g. "payment_success", "daily_digest"
  triggerValue String     @map("trigger_value")
  category     String
  
  // Убрали textRu.
  
  weight       Int        @default(1)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  translations ContentTemplateTranslation[]

  @@index([triggerType, triggerValue])
  @@map("content_templates")
}

// НОВАЯ МОДЕЛЬ: Переводы шаблонов
model ContentTemplateTranslation {
  id         String          @id @default(uuid())
  templateId String          @map("template_id")
  locale     String          @default("ru")
  text       String          @db.Text // Сам текст сообщения

  template   ContentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
  @@map("content_template_translations")
}

model Delivery {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  deliveryDate      DateTime @map("delivery_date") @db.Date
  forecastId        String?  @map("forecast_id")
  telegramMessageId String?  @map("telegram_message_id")
  opened            Boolean  @default(false)
  streakCount       Int      @default(1) @map("streak_count")
  
  // Здесь полезно хранить снапшот того, что реально ушло юзеру 
  // (чтобы при разборе полетов видеть текст на нужном языке)
  sentContentSnapshot Json     @default("{}") @map("sent_content_snapshot")
  
  deliveredAt       DateTime? @map("delivered_at")
  createdAt         DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  forecast Forecast? @relation(fields: [forecastId], references: [id])

  @@index([userId, deliveryDate])
  @@map("deliveries")
}

model UserPartner {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  partnerSign ZodiacSign @map("partner_sign")
  partnerName String?    @map("partner_name")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_partners")
}

model GiftSubscription {
  id                  String   @id @default(uuid())
  senderUserId        String?  @map("sender_user_id")
  recipientTelegramId BigInt?  @map("recipient_telegram_id")
  planId              String   @map("plan_id")
  durationDays        Int      @default(30) @map("duration_days")
  paymentId           String?  @unique @map("payment_id")
  redeemed            Boolean  @default(false)
  redeemedAt          DateTime? @map("redeemed_at")
  code                String   @unique
  createdAt           DateTime @default(now()) @map("created_at")

  sender  User?    @relation("GiftSender", fields: [senderUserId], references: [id])
  plan    Plan     @relation(fields: [planId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("gift_subscriptions")
}

// Логи можно оставить без изменений
enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel
  source    String  
  action    String  
  message   String  
  meta      Json?   
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}