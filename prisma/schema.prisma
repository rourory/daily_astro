generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- ENUMS ----------------

enum ZodiacSign {
  aries
  taurus
  gemini
  cancer
  leo
  virgo
  libra
  scorpio
  sagittarius
  capricorn
  aquarius
  pisces
}

enum SubscriptionStatus {
  trial
  active
  canceled
  expired
  grace
  paused
  pending
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  canceled
}

enum PlanName {
  basic
  plus
  premium
}

enum Currency {
  BYN
  RUB
  USD
  CNY
  KZT
}

// ---------------- MODELS ----------------

model User {
  id           String      @id @default(uuid())
  // Убрали telegramId. Email теперь обязательное и уникальное поле.
  email        String      @unique
  zodiacSign   ZodiacSign? @map("zodiac_sign")
  birthDate    DateTime?   @map("birth_date") @db.Date
  
  timezone     String      @default("Europe/Minsk")
  locale       String      @default("ru") 
  countryCode  String?     @map("country_code") @db.Char(2)

  // Время доставки писем
  deliveryTime String      @default("07:00:00") @map("delivery_time")
  isPaused     Boolean     @default(false) @map("is_paused")

  emailNotification Boolean @default(true)
  
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  subscriptions    Subscription[]
  payments         Payment[]
  deliveries       Delivery[]
  partners         UserPartner[]
  giftsSent        GiftSubscription[] @relation("GiftSender")
  pushSubscriptions PushSubscription[]

  @@index([zodiacSign])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  
  endpoint  String   @unique // Уникальный URL от браузера
  keys      Json     // Объект { p256dh: "...", auth: "..." }
  
  userAgent String?  // Полезно знать, это Chrome на Android или Safari на iPhone
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// Модель для хранения OTP кодов (добавлена из предыдущего шага)
model VerificationToken {
  identifier String   // Email
  token      String   // Код
  expires    DateTime 
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Plan {
  id            String   @id @default(uuid())
  name          PlanName @unique
  createdAt     DateTime @default(now()) @map("created_at")
  prices        PlanPrice[]
  subscriptions Subscription[]
  giftSubscriptions GiftSubscription[]

  @@map("plans")
}

model PlanPrice {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  currency  Currency 
  amount    Int      
  locale    String   @default("ru") 
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, currency])
  @@map("plan_prices")
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  planId          String             @map("plan_id")
  
  status          SubscriptionStatus @default(trial)
  currency        Currency           @default(BYN) 
  priceAmount     Int                @map("price_amount") 

  trialEndsAt     DateTime?          @map("trial_ends_at")
  startAt         DateTime           @default(now()) @map("start_at")
  renewAt         DateTime?          @map("renew_at")
  canceledAt      DateTime?          @map("canceled_at")
  
  paymentProvider String             @default("yookassa") @map("payment_provider")
  paymentToken    String?            @map("payment_token") 
  externalSubId   String?            @map("external_sub_id")
  lastPaymentId   String?            @map("last_payment_id")
  
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  subscriptionId    String?       @map("subscription_id")
  providerPaymentId String?       @map("provider_payment_id") 
  orderId           String        @unique @map("order_id")
  
  amount            Int           
  currency          Currency      @default(BYN)
  status            PaymentStatus @default(pending)
  isRecurring       Boolean       @default(false) @map("is_recurring")
  
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  giftSubscription GiftSubscription?

  @@index([orderId])
  @@index([userId])
  @@map("payments")
}

model AstroEvent {
  id          String     @id @default(uuid())
  eventDate   DateTime   @map("event_date") @db.Date
  planet      String
  sign        ZodiacSign?
  aspect      String?
  magnitude   Float?
  source      String?    // Техническое поле источника данных
  
  // Описание может быть на разных языках, поэтому лучше JSONB 
  // или отдельная таблица. Для событий часто хватает JSONB: {"ru": "...", "en": "..."}
  description Json?      
  
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([eventDate])
  @@map("astro_events")
}

model Forecast {
  id           String     @id @default(uuid())
  forecastDate DateTime   @map("forecast_date") @db.Date
  zodiacSign   ZodiacSign @map("zodiac_sign")
  luckyMetrics Json       @default("{}") @map("lucky_metrics")
  source       Json       @default("{}")
  generatedAt  DateTime   @default(now()) @map("generated_at")

  translations ForecastTranslation[] 
  deliveries   Delivery[]

  @@unique([forecastDate, zodiacSign])
  @@map("forecasts")
}

model ForecastTranslation {
  id          String   @id @default(uuid())
  forecastId  String   @map("forecast_id")
  locale      String   @default("ru")
  
  love        String   @db.Text
  money       String   @db.Text
  mood        String   @db.Text
  advice      String   @db.Text
  affirmation String   @default("") @db.Text
  compatibility Json   @default("{}")
  tomorrowInsight String @default("") @map("tomorrow_insight") @db.Text

  forecast    Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, locale]) 
  @@map("forecast_translations")
}

// ИЗМЕНЕНО: Шаблоны уведомлений теперь мультиязычные
model ContentTemplate {
  id           String     @id @default(uuid())
  zodiacSign   ZodiacSign? @map("zodiac_sign")
  triggerType  String     @map("trigger_type") // e.g. "payment_success", "daily_digest"
  triggerValue String     @map("trigger_value")
  category     String
  
  // Убрали textRu.
  
  weight       Int        @default(1)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  translations ContentTemplateTranslation[]

  @@index([triggerType, triggerValue])
  @@map("content_templates")
}

// НОВАЯ МОДЕЛЬ: Переводы шаблонов
model ContentTemplateTranslation {
  id         String          @id @default(uuid())
  templateId String          @map("template_id")
  locale     String          @default("ru")
  text       String          @db.Text // Сам текст сообщения

  template   ContentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
  @@map("content_template_translations")
}

model Delivery {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  deliveryDate      DateTime @map("delivery_date") @db.Date
  forecastId        String?  @map("forecast_id")
  
  // Убрали telegramMessageId
  
  opened            Boolean  @default(false)
  streakCount       Int      @default(1) @map("streak_count")
  sentContentSnapshot Json     @default("{}") @map("sent_content_snapshot")
  deliveredAt       DateTime? @map("delivered_at")
  createdAt         DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  forecast Forecast? @relation(fields: [forecastId], references: [id])

  @@index([userId, deliveryDate])
  @@map("deliveries")
}


model UserPartner {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  partnerSign ZodiacSign @map("partner_sign")
  partnerName String?    @map("partner_name")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_partners")
}

model GiftSubscription {
  id                  String   @id @default(uuid())
  senderUserId        String?  @map("sender_user_id")
  
  // Заменили recipientTelegramId на recipientEmail
  recipientEmail      String?  @map("recipient_email")
  
  planId              String   @map("plan_id")
  durationDays        Int      @default(30) @map("duration_days")
  paymentId           String?  @unique @map("payment_id")
  redeemed            Boolean  @default(false)
  redeemedAt          DateTime? @map("redeemed_at")
  code                String   @unique
  createdAt           DateTime @default(now()) @map("created_at")

  sender  User?    @relation("GiftSender", fields: [senderUserId], references: [id])
  plan    Plan     @relation(fields: [planId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("gift_subscriptions")
}

// Логи можно оставить без изменений
enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel
  source    String  
  action    String  
  message   String  
  meta      Json?   
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}